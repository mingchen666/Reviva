{
  "id": "agent_lab_report",
  "name": "实验报告助手",
  "english_name": "lab-report-assistant",
  "description": "根据实验要求、模板、数据和资料生成或完善专业实验报告，支持 Word 文档输出和模板编辑。",
  "icon": "ri-flask-line",
  "color": "#14B8A6",
  "architecture": "plan_exec",
  "builtin": true,
  "category": "创作中心",
  "permissions": {
    "fileRead": true,
    "fileWrite": true,
    "webSearch": true,
    "fileDelete": false,
    "fileRename": false,
    "execCommand": false
  },
  "tools": ["office_read", "office_write", "file_read", "file_write", "kb_search", "web_search_bing"],
  "skills": ["lab-report-writer", "officecli-skills"],
  "sub_agents": [],
  "max_iterations": 10,
  "plan_steps": 5,
  "temperature": 0.25,
  "max_tokens": 16384,
  "thinking_mode": "auto",
  "thinking_intensity": "medium",
  "hard_timeout_ms": 600000,
  "required_tools": [],
  "prompt_file": "orchestrator.md",
  "subagent_dir": "subagents",
  "artifact_rules_file": "artifact-rules.json",
  "output_formats": ["docx", "md"],
  "default_format": "docx"
}
