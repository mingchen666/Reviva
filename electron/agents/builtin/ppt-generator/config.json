{
  "id": "agent_ppt",
  "name": "PPT 生成器",
  "english_name": "ppt-generator",
  "description": "根据资料和需求生成精美演示文稿，支持 HTML 和 PPTX 格式",
  "icon": "ri-slideshow-line",
  "color": "#6C8AFF",
  "architecture": "plan_exec",
  "builtin": true,
  "category": "创作中心",
  "permissions": {
    "fileRead": true,
    "fileWrite": true,
    "webSearch": true,
    "fileDelete": false,
    "fileRename": false,
    "execCommand": false
  },
  "tools": ["mcp:exa", "web_search_bing", "file_read", "file_write", "kb_search"],
  "skills": ["ppt-creation"],
  "sub_agents": ["content-planner", "slide-builder", "pptx-exporter", "visual-reviewer"],
  "max_iterations": 0,
  "plan_steps": 6,
  "temperature": 0.4,
  "max_tokens": 16384,
  "thinking_mode": "auto",
  "thinking_intensity": "medium",
  "hard_timeout_ms": 600000,
  "required_tools": ["mcp:exa"],
  "prompt_file": "orchestrator.md",
  "subagent_dir": "subagents",
  "artifact_rules_file": "artifact-rules.json",
  "output_formats": ["html", "pptx-local", "pptx-cloud"],
  "default_format": "html"
}
