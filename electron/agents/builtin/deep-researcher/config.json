{
  "id": "agent_researcher",
  "name": "深度研究员",
  "english_name": "deep-researcher",
  "description": "对文件和网上信息进行深度研究，生成研究报告和可视化报告",
  "icon": "ri-search-eye-line",
  "color": "#38BDF8",
  "architecture": "plan_exec",
  "builtin": true,
  "category": "创作中心",
  "permissions": {
    "fileRead": true,
    "fileWrite": true,
    "webSearch": true,
    "fileDelete": false,
    "fileRename": false,
    "execCommand": false
  },
  "tools": ["mcp:exa", "mcp:jina-mcp-server", "web_search_bing", "file_read", "file_write", "kb_search"],
  "skills": ["deep-research"],
  "sub_agents": ["web-researcher", "local-analyst", "report-writer"],
  "max_iterations": 15,
  "plan_steps": 7,
  "temperature": 0.3,
  "max_tokens": 8192,
  "thinking_mode": "auto",
  "thinking_intensity": "medium",
  "hard_timeout_ms": 600000,
  "required_tools": ["mcp:exa"],
  "prompt_file": "orchestrator.md",
  "subagent_dir": "subagents",
  "artifact_rules_file": "artifact-rules.json",
  "output_formats": ["md", "html"]
}
