{
  "name": "reviva-desktop",
  "private": true,
  "author": "Reviva",
  "license": "AGPL-3.0",
  "description": "Reviva",
  "version": "0.0.1-beta",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "cross-env NODE_OPTIONS=--max-old-space-size=8192 vite build && electron-builder",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "preview": "vite preview",
    "migrate-db": "node scripts/migrate-db.js",
    "postinstall": "electron-builder install-app-deps",
    "build:electron": "cross-env NODE_OPTIONS=--max-old-space-size=8192 vite build"
  },
  "pnpm": {
    "peerDependencyRules": {
      "ignoreMissing": []
    },
    "onlyBuiltDependencies": [
      "electron",
      "better-sqlite3"
    ]
  },
  "dependencies": {
    "@langchain/anthropic": "^1.3.29",
    "@langchain/core": "^1.1.46",
    "@langchain/langgraph": "^1.3.0",
    "@langchain/mcp-adapters": "^1.1.3",
    "@langchain/openai": "^1.4.5",
    "@langchain/tavily": "^1.2.0",
    "better-sqlite3": "^12.9.0",
    "deepagents": "^1.10.2",
    "electron-updater": "^6.8.3",
    "langchain": "^1.4.0",
    "langsmith": "~0.6.3",
    "mathjs": "^15.2.0",
    "pptxgenjs": "^4.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@antv/g6": "^5.1.1",
    "@electron/rebuild": "^4.0.4",
    "@vitejs/plugin-vue": "^5.0.4",
    "@vueuse/core": "^14.3.0",
    "axios": "^1.16.1",
    "cross-env": "^10.1.0",
    "electron": "^30.0.1",
    "electron-builder": "^24.13.3",
    "highlight.js": "^11.11.1",
    "katex": "^0.17.0",
    "markdown-it": "^14.2.0",
    "markstream-vue": "1.0.1-beta.1",
    "mermaid": "^11.15.0",
    "naive-ui": "^2.43.2",
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate": "^4.7.1",
    "remixicon": "^4.9.1",
    "sass": "^1.97.3",
    "simple-mind-map": "0.14.0-fix.2",
    "sql.js": "^1.14.1",
    "stream-markdown": "^0.0.15",
    "typescript": "^5.2.2",
    "unocss": "^66.6.0",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^31.0.0",
    "vite": "^5.1.6",
    "vite-plugin-electron": "^0.28.6",
    "vite-plugin-electron-renderer": "^0.14.5",
    "vite-plugin-svg-icons": "^2.0.1",
    "vue": "^3.5.34",
    "vue-router": "^5.0.7",
    "vue-tsc": "^2.0.26"
  },
  "main": "dist-electron/main.js"
}
